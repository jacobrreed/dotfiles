include Eldritch.conf

# Font
font_size 18
# font_family JetBrains Mono Regular
font_family JetBrains Mono
bold_font JetBrains Mono Bold
italic_font JetBrains Mono Italic
bold_italic_font JetBrains Mono Bold Italic
# Nerd Fonts v2.3.3
bold_font auto
italic_font auto
bold_italic_font auto
disable_ligatures never
# Nerd Fonts v3.1.0
# https://github.com/ryanoasis/nerd-fonts/wiki/Glyph-Sets-and-Code-Points
symbol_map U+E5FA-U+E62B Symbols Nerd Font Mono
# Devicons
symbol_map U+e700-U+e7c5 Symbols Nerd Font Mono
# Font Awesome
symbol_map U+f000-U+f2e0 Symbols Nerd Font Mono
# Font Awesome Extension
symbol_map U+e200-U+e2a9 Symbols Nerd Font Mono
# Material Design Icons
symbol_map U+f0001-U+f1af0 Symbols Nerd Font Mono
# Weather
symbol_map U+e300-U+e3e3 Symbols Nerd Font Mono
# Octicons
symbol_map U+f400-U+f532 Symbols Nerd Font Mono
symbol_map U+2665 Symbols Nerd Font Mono
symbol_map U+26A1 Symbols Nerd Font Mono
# [Powerline Symbols]
symbol_map U+e0a0-U+e0a2 Symbols Nerd Font Mono
symbol_map U+e0b0-U+e0b3 Symbols Nerd Font Mono
# Powerline Extra Symbols
symbol_map U+e0b4-U+e0c8 Symbols Nerd Font Mono
symbol_map U+e0cc-U+e0d4 Symbols Nerd Font Mono
symbol_map U+e0a3 Symbols Nerd Font Mono
symbol_map U+e0ca Symbols Nerd Font Mono
# IEC Power Symbols
symbol_map U+23fb-U+23fe Symbols Nerd Font Mono
symbol_map U+2b58 Symbols Nerd Font Mono
# Font Logos (Formerly Font Linux)
symbol_map U+f300-U+f32f Symbols Nerd Font Mono
# Pomicons
symbol_map U+e000-U+e00a Symbols Nerd Font Mono
# Codicons
symbol_map U+ea60-U+ebeb Symbols Nerd Font Mono
# Box Drawing
symbol_map U+2500-U+259f Symbols Nerd Font Mono

#: Kitty modifier key
kitty_mod ctrl+shift

# Cursor
cursor_shape block
cursor_blink_interval 1

# Scrollback
scrollback_lines 10000
scrollback_pager less --chop-long-lines --RAW-CONTROL-CHARS +INPUT_LINE_NUMBER
scrollback_pager_history_size 4096
scrollback_indicator_opacity 1.0

# Mouse
url_style dotted
open_url_with default
url_prefixes file ftp ftps gemini git gopher http https irc ircs kitty mailto news sftp ssh
detect_urls yes
underline_hyperlinks always
paste_actions quote-urls-at-prompt
focus_follows_mouse yes

# Performance Tuning
repaint_delay 1
input_delay 1
sync_to_monitor yes

# Terminal bell
enable_audio_bell no
visual_bell_duration 0
bell_on_tab "🔔"

# Window layout
enabled_layouts splits,stack
remember_window_size yes
draw_minimal_borders no
window_border_width 0
window_margin_width 0 0 0 1
window_padding_width 0
single_window_margin_width 0
inactive_text_alpha 0.5
single_window_padding_width -1
background_opacity 0.90
hide_window_decorations titlebar-only
confirm_os_window_close 0
background_blur 20
background_tint 0.9

# Tab bar
active_tab_font_style normal
inactive_tab_font_style normal
tab_bar_margin_width 0
tab_bar_margin_height 0.0 0.0
tab_bar_style powerline
tab_powerline_style round
tab_bar_align left
tab_bar_min_tabs 1
active_tab_font_style bold
inactive_tab_font_style bold
tab_title_template "{fmt.fg.red}{bell_symbol}{activity_symbol}{fmt.fg.tab} {title}"
active_tab_title_template "{fmt.fg.red}{bell_symbol}{activity_symbol}{fmt.fg.tab} {title}"

# Advanced
editor .
allow_remote_control yes
listen_on unix:/tmp/mykitty
update_check_interval 6
# startup_session launch.conf
clipboard_max_size 512
allow_hyperlinks yes
shell_integration enabled
term xterm-kitty
## OS Specific Tweaks
### MacOS
macos_show_window_title_in none
macos_option_as_alt yes
macos_window_resizable yes
macos_custom_beam_cursor yes
### Wayland
linux_display_server wayland
wayland_enable_ime no

# Keyboard shortcuts
map cmd+enter no_op
## Copy/Paste
map cmd+c copy_to_clipboard
map cmd+v paste_from_clipboard
map kitty_mod+c copy_to_clipboard
map kitty_mod+v paste_from_clipboard
mouse_map right click grabbed,ungrabbed paste_from_clipboard
copy_on_select clipboard
## Scrolling
map kitty_mod+up scroll_page_up
map kitty_mod+down scroll_page_down
### Shell integration
map kitty_mod+j scroll_to_prompt 1
map kitty_mod+k scroll_to_prompt -1
map kitty_mod+o show_last_command_output
## Tmux like stuff
map ctrl+t>v launch --location=vsplit --cwd=current
map ctrl+t>b launch --location=hsplit --cwd=current
map ctrl+t>; detach_window ask
map ctrl+t>x close_window
### Move windows up/down/left/right
map ctrl+t>down layout_action move_to_screen_edge bottom
map ctrl+t>up layout_action move_to_screen_edge top
map ctrl+t>right layout_action move_to_screen_edge right
map ctrl+t>left layout_action move_to_screen_edge left
# Resize mode
window_resize_step_cell 5
window_resize_step_lines 5
map ctrl+t>r kitten resize_window
# map --new-mode resizing ctrl+t>r
# map --mode resizing j resize_window shorter
# map --mode resizing k resize_window taller
# map --mode resizing h resize_window wider
# map --mode resizing l resize_window narrower
# map --mode resizing esc pop_keyboard_mode
# End resize mode
map ctrl+t>f focus_visible_window
map ctrl+t>s swap_with_window
# https://github.com/knubie/vim-kitty-navigator
map ctrl+j kitten pass_keys.py bottom ctrl+j
map ctrl+k kitten pass_keys.py top    ctrl+k
map ctrl+h kitten pass_keys.py left   ctrl+h
map ctrl+l kitten pass_keys.py right  ctrl+l
### Layout binds
map kitty_mod+f toggle_layout stack
### Tab keybinds
map ctrl+t>1 goto_tab 1
map ctrl+t>2 goto_tab 2
map ctrl+t>3 goto_tab 3
map ctrl+t>4 goto_tab 4
map ctrl+t>5 goto_tab 5
map kitty_mod+
map ctrl+t>n next_tab
map ctrl+t>p previous_tab
map ctrl+t>c new_tab_with_cwd
map ctrl+t>t set_tab_title
map cmd+w close_tab
map ctrl+t>w close_tab
map ctrl+t>, move_tab_backward
map ctrl+t>. move_tab_forward
### Font Management
map kitty_mod+plus change_font_size all +1.0
map kitty_mod+minus change_font_size all -1.0
### Miscellaneous
map f11 toggle_fullscreen
map f12 kitten unicode_input --tab name --emoji-variation graphic
map kitty_mod+r load_config_file
#### Urls
map kitty_mod+e open_url_with_hints
undercurl_style thick-sparse
url_style curly
detect_urls yes
show_hyperlink_targets yes
underline_hyperlinks always
### Marks
map f1 toggle_marker text 1 TEST 
map f2 toggle_marker text 2 ERROR
