[include]
  path= .gitconfig.local
[core]
  editor=nvim
[init]
  defaultBranch= master
[core]
  pager=delta
[interactive]
  diffFilter=delta --color-only
[delta]
  navigate=true
  side-by-side=true
[pull]
  rebase=true
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
